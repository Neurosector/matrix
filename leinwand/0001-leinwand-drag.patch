index 00000000..627a78da
--- /dev/null
+++ b/src/layout/floating_leinwand.rs
@@ -0,0 +1,255 @@
+//! Matrix Leinwand — Kamera (blick), Blättern, Heimweg, Geist-Info,
+//! Spawn-Ordnung und Ent-Überlappung der FloatingSpace (R46: aus
+//! floating.rs herausgehoben; Kind-Modul, sieht die privaten Felder).
+
+use super::*;
+
+impl<W: LayoutElement> FloatingSpace<W> {
+    /// Leinwand-Modus aktiv? (Config: gestures { leinwand-drag })
+    pub(super) fn leinwand(&self) -> bool {
+        self.options.gestures.leinwand_drag
+    }
+
+    /// Die Kamera verschieben: die Ebene folgt dem Cursor (Papier greifen).
+    pub fn leinwand_pan(&mut self, delta: Point<f64, Logical>) {
+        if self.leinwand() {
+            self.blick -= delta;
+        }
+    }
+
+    /// Heimweg: die Kamera so setzen, dass der Schwerpunkt aller Fenster
+    /// mittig in der Arbeitsfläche liegt — gegen das Verlaufen auf der
+    /// unendlichen Ebene. (Aufruf federt über tiles_with_render_positions.)
+    pub fn leinwand_heimweg(&mut self) {
+        if !self.leinwand() || self.data.is_empty() {
+            return;
+        }
+        let mut mitte = Point::from((0.0, 0.0));
+        for d in &self.data {
+            mitte += d.logical_pos + d.size.downscale(2.0).to_point();
+        }
+        let n = self.data.len() as f64;
+        mitte = Point::from((mitte.x / n, mitte.y / n));
+        let ziel = self.working_area.loc + self.working_area.size.downscale(2.0).to_point();
+        self.blick = mitte - ziel;
+    }
+
+    /// Fenster-Geist (Matrix-Original, 7.7.): Zentren aller Leinwand-
+    /// Fenster + Markierung des Fensters, das der Sichtmitte am nächsten
+    /// liegt — Grundlage der Icon-Wolke neben der Maus.
+    pub fn leinwand_geist_info(&self) -> Vec<(W::Id, Point<f64, Logical>, bool)> {
+        if !self.leinwand() || self.data.is_empty() {
+            return Vec::new();
+        }
+        let sichtmitte =
+            self.working_area.loc + self.working_area.size.downscale(2.0).to_point() + self.blick;
+        let zentren: Vec<Point<f64, Logical>> = self
+            .data
+            .iter()
+            .map(|d| d.logical_pos + d.size.downscale(2.0).to_point())
+            .collect();
+        let naechst = (0..zentren.len()).min_by(|&a, &b| {
+            let da = zentren[a] - sichtmitte;
+            let db = zentren[b] - sichtmitte;
+            (da.x * da.x + da.y * da.y).total_cmp(&(db.x * db.x + db.y * db.y))
+        });
+        self.tiles
+            .iter()
+            .zip(zentren)
+            .enumerate()
+            .map(|(i, (tile, z))| (tile.window().id().clone(), z, Some(i) == naechst))
+            .collect()
+    }
+
+    /// Leinwand-Blättern (Nutzer-Idee 7.7.): das Mausrad auf dem Leerraum
+    /// wandert durch die Fenster — räumlich sortiert (links→rechts,
+    /// Gleichstand oben→unten). Die Kamera zentriert das gewählte Fenster
+    /// (damit ist es voll sichtbar), die Fahrt federt wie ein Magic-Move.
+    /// Gibt das Fenster zurück, das den Fokus bekommen soll.
+    pub fn leinwand_blaettern(&mut self, richtung: i32) -> Option<W::Id> {
+        if !self.leinwand() || self.data.is_empty() {
+            return None;
+        }
+        let zentren: Vec<Point<f64, Logical>> = self
+            .data
+            .iter()
+            .map(|d| d.logical_pos + d.size.downscale(2.0).to_point())
+            .collect();
+        let mut reihenfolge: Vec<usize> = (0..zentren.len()).collect();
+        reihenfolge.sort_by(|&a, &b| {
+            zentren[a]
+                .x
+                .total_cmp(&zentren[b].x)
+                .then(zentren[a].y.total_cmp(&zentren[b].y))
+        });
+        // „Aktuell" = das Fenster, dessen Zentrum der Sichtmitte am
+        // nächsten liegt — das, was der Blick gerade für vorn hält.
+        let sichtmitte =
+            self.working_area.loc + self.working_area.size.downscale(2.0).to_point() + self.blick;
+        let naechstes = (0..zentren.len()).min_by(|&a, &b| {
+            let da = zentren[a] - sichtmitte;
+            let db = zentren[b] - sichtmitte;
+            (da.x * da.x + da.y * da.y).total_cmp(&(db.x * db.x + db.y * db.y))
+        })?;
+        let pos = reihenfolge.iter().position(|&i| i == naechstes)? as i64;
+        let n = reihenfolge.len() as i64;
+        let ziel = reihenfolge[(pos + richtung as i64).rem_euclid(n) as usize];
+
+        // Kamera aufs Ziel zentrieren — voll sichtbar, solange das Fenster
+        // auf den Schirm passt; die Tiles federn von der alten Sicht herüber.
+        let alt = self.blick;
+        self.blick = zentren[ziel]
+            - (self.working_area.loc + self.working_area.size.downscale(2.0).to_point());
+        let diff = self.blick - alt;
+        if diff.x * diff.x + diff.y * diff.y > 4.0 {
+            for tile in &mut self.tiles {
+                tile.animate_move_from(diff);
+            }
+        }
+        Some(self.tiles[ziel].window().id().clone())
+    }
+
+    /// Fenster-Klick auf der Leinwand (Nutzer-Idee 7.7.): ein NICHT voll
+    /// sichtbares Fenster fährt beim Anklicken ganz in die Sicht — wie
+    /// beim Rad-Blättern. Voll sichtbare Fenster bleiben ruhig, damit
+    /// Arbeitsklicks (Knöpfe, Text) die Kamera nie verreißen.
+    /// Gibt true zurück, wenn die Kamera gefahren ist.
+    pub fn leinwand_fenster_zeigen(&mut self, id: &W::Id) -> bool {
+        if !self.leinwand() {
+            return false;
+        }
+        let Some(i) = self.tiles.iter().position(|t| t.window().id() == id) else {
+            return false;
+        };
+        let fenster = Rectangle::new(self.data[i].logical_pos, self.data[i].size);
+        let sicht = Rectangle::new(self.working_area.loc + self.blick, self.working_area.size);
+        // Toleranz: 2px Rundungsluft zählt noch als „voll sichtbar".
+        let luft = 2.0;
+        let drin = fenster.loc.x >= sicht.loc.x - luft
+            && fenster.loc.y >= sicht.loc.y - luft
+            && fenster.loc.x + fenster.size.w <= sicht.loc.x + sicht.size.w + luft
+            && fenster.loc.y + fenster.size.h <= sicht.loc.y + sicht.size.h + luft;
+        if drin {
+            return false;
+        }
+        let alt = self.blick;
+        let zentrum = fenster.loc + fenster.size.downscale(2.0).to_point();
+        self.blick =
+            zentrum - (self.working_area.loc + self.working_area.size.downscale(2.0).to_point());
+        let diff = self.blick - alt;
+        if diff.x * diff.x + diff.y * diff.y > 4.0 {
+            for tile in &mut self.tiles {
+                tile.animate_move_from(diff);
+            }
+        }
+        true
+    }
+
+    /// Leinwand-Spawn: freie Stelle nahe der aktuellen Sicht — Fenster
+    /// öffnen NEBENEINANDER, nie überlappend (Ring-Suche um die Mitte).
+    pub(super) fn leinwand_spawn_pos(&self, size: Size<f64, Logical>) -> Point<f64, Logical> {
+        let basis = center_preferring_top_left_in_area(self.working_area, size) + self.blick;
+        let frei = |p: Point<f64, Logical>| {
+            let kandidat = Rectangle::new(p, size);
+            !self
+                .data
+                .iter()
+                .any(|d| kandidat.overlaps(Rectangle::new(d.logical_pos, d.size)))
+        };
+        if frei(basis) {
+            return basis;
+        }
+        let schritt = 64.0;
+        for ring in 1..=16 {
+            let r = ring as f64 * schritt;
+            for (dx, dy) in [
+                (r, 0.0), (-r, 0.0), (0.0, r), (0.0, -r),
+                (r, r), (-r, r), (r, -r), (-r, -r),
+            ] {
+                let p = basis + Point::from((dx, dy));
+                if frei(p) {
+                    return p;
+                }
+            }
+        }
+        basis
+    }
+
+    /// Leinwand-Regel: Fenster überlappen NIE. Der Verursacher (,
+    /// z. B. das vergrößerte oder fallengelassene Fenster) bleibt stehen —
+    /// überlappte Nachbarn weichen entlang der kleinsten Trennachse aus,
+    /// kaskadierend, bis Ruhe herrscht (Nutzer-Feedback 7.7.: „Fenster
+    /// gewöhnen sich nicht an die neue Größe").
+    pub(super) fn leinwand_entueberlappen(&mut self, fest: usize) {
+        if !self.leinwand() || self.data.len() < 2 {
+            return;
+        }
+        const LUFT: f64 = 16.0;
+        for _ in 0..64 {
+            let mut bewegt = false;
+            for i in 0..self.data.len() {
+                for j in 0..self.data.len() {
+                    if i == j || j == fest {
+                        continue;
+                    }
+                    // Bei Nicht-Verursacher-Paaren nur eine Richtung prüfen,
+                    // sonst schieben sich i und j gegenseitig endlos.
+                    if i != fest && i > j {
+                        continue;
+                    }
+                    let a = Rectangle::new(self.data[i].logical_pos, self.data[i].size);
+                    let b = Rectangle::new(self.data[j].logical_pos, self.data[j].size);
+                    if !a.overlaps(b) {
+                        continue;
+                    }
+                    // R57 (Nutzer-Fund): Liegt ein Fenster VOLLSTAENDIG im
+                    // anderen, ist das GEWOLLT (Matrix Webs Andock-Kopplung
+                    // legt den WebKit-Traeger deckungsgleich unter die
+                    // Chrome). Solche Paare laesst die Ent-Ueberlappung in
+                    // Ruhe — sonst kaempfen Kopplung und Ordnung endlos
+                    // (das war das Glitchen des weissen Fensters).
+                    let umschliesst = |aussen: Rectangle<f64, Logical>,
+                                       innen: Rectangle<f64, Logical>| {
+                        let luft = 4.0;
+                        innen.loc.x >= aussen.loc.x - luft
+                            && innen.loc.y >= aussen.loc.y - luft
+                            && innen.loc.x + innen.size.w
+                                <= aussen.loc.x + aussen.size.w + luft
+                            && innen.loc.y + innen.size.h
+                                <= aussen.loc.y + aussen.size.h + luft
+                    };
+                    if umschliesst(a, b) || umschliesst(b, a) {
+                        continue;
+                    }
+                    // Kleinste Trennachse: j weicht vor i aus.
+                    let nach_rechts = a.loc.x + a.size.w - b.loc.x + LUFT;
+                    let nach_links = b.loc.x + b.size.w - a.loc.x + LUFT;
+                    let nach_unten = a.loc.y + a.size.h - b.loc.y + LUFT;
+                    let nach_oben = b.loc.y + b.size.h - a.loc.y + LUFT;
+                    let min = nach_rechts.min(nach_links).min(nach_unten).min(nach_oben);
+                    let offset = if min == nach_rechts {
+                        Point::from((nach_rechts, 0.0))
+                    } else if min == nach_links {
+                        Point::from((-nach_links, 0.0))
+                    } else if min == nach_unten {
+                        Point::from((0.0, nach_unten))
+                    } else {
+                        Point::from((0.0, -nach_oben))
+                    };
+                    let vorher = self.data[j].logical_pos;
+                    let neu = vorher + offset;
+                    self.data[j].set_logical_pos(neu);
+                    // Federndes Ausweichen (Magic-Move) statt Springen.
+                    let diff = vorher - self.data[j].logical_pos;
+                    if diff.x * diff.x + diff.y * diff.y > 4.0 {
+                        self.tiles[j].animate_move_from(diff);
+                    }
+                    bewegt = true;
+                }
+            }
+            if !bewegt {
+                break;
+            }
+        }
+    }
+}
