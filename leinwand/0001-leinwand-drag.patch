diff --git a/src/input/leinwand.rs b/src/input/leinwand.rs
new file mode 100644
index 00000000..c734027e
--- /dev/null
+++ b/src/input/leinwand.rs
@@ -0,0 +1,280 @@
+//! Matrix Leinwand — die Leerraum-Gesten (R46: aus input/mod.rs
+//! herausgehoben). Maus-Drag (2D-Pan), Klick-holt, Rechtsklick-Menü,
+//! Rad-/Finger-Blättern mit Klebe-Puffer, Ein-Finger-Touch-Wisch.
+//! Kind-Modul von input — sieht dessen private Helfer.
+
+use smithay::backend::input::{AxisSource, MouseButton, TouchSlot};
+use smithay::input::pointer::{CursorIcon, CursorImageStatus, Focus, GrabStartData as PointerGrabStartData};
+use smithay::utils::{Logical, Point, Serial};
+
+use super::modifiers_from_state;
+use super::spatial_movement_grab::SpatialMovementGrab;
+use crate::leinwand::leerraum;
+use crate::niri::{PointContents, State};
+
+/// Fokus von außen (Dock-Klick, Fenster-Geist): die Kamera fährt zum
+/// Fenster — dieselbe Fahrt wie der Leinwand-Klick (Task #33).
+pub fn fokus_kamera(state: &mut State, window: &smithay::desktop::Window) {
+    if state.niri.config.borrow().gestures.leinwand_drag
+        && crate::utils::matrix_schalter_an("leinwand-klick-holt")
+        && state.niri.layout.leinwand_fenster_zeigen(window)
+    {
+        // FIXME: granular.
+        state.niri.queue_redraw_all();
+    }
+}
+
+/// Links-Ziehen auf dem LEERRAUM schwenkt die Sicht in alle Richtungen —
+/// der Desktop als unendliche Leinwand. true = Grab gesetzt, Ereignis
+/// verzehrt. Aktivierung: gestures { leinwand-drag } in der Config.
+pub fn drag_start(
+    state: &mut State,
+    button: Option<MouseButton>,
+    button_code: u32,
+    serial: Serial,
+    is_overview_open: bool,
+) -> bool {
+    if button != Some(MouseButton::Left) {
+        return false;
+    }
+    let pointer = state.niri.seat.get_pointer().unwrap();
+    if pointer.is_grabbed()
+        || is_overview_open
+        || !state.niri.config.borrow().gestures.leinwand_drag
+    {
+        return false;
+    }
+    let location = pointer.current_location();
+    let under = state.niri.contents_under(location);
+    if !leerraum(&under) {
+        return false;
+    }
+    let output_ws = state.niri.output_under_cursor().and_then(|output| {
+        let mon = state.niri.layout.monitor_for_output(&output)?;
+        Some((output, mon.active_workspace_ref().id()))
+    });
+    let Some((output, ws_id)) = output_ws else {
+        return false;
+    };
+    state.niri.layout.focus_output(&output);
+    let start_data = PointerGrabStartData {
+        focus: None,
+        button: button_code,
+        location,
+    };
+    let grab = SpatialMovementGrab::new_leinwand(start_data, output, ws_id);
+    pointer.set_grab(state, grab, serial, Focus::Clear);
+    state
+        .niri
+        .cursor_manager
+        .set_cursor_image(CursorImageStatus::Named(CursorIcon::AllScroll));
+    state.niri.queue_redraw_all();
+    true
+}
+
+/// Klick auf ein ANGESCHNITTENES Fenster fährt es ganz in die Sicht —
+/// voll sichtbare Fenster bleiben ruhig, damit Arbeitsklicks die
+/// Kamera nie verreißen.
+pub fn klick_holt(state: &mut State, is_overview_open: bool, mod_down: bool) {
+    let pointer = state.niri.seat.get_pointer().unwrap();
+    if is_overview_open
+        || mod_down
+        || pointer.is_grabbed()
+        || !state.niri.config.borrow().gestures.leinwand_drag
+        || !crate::utils::matrix_schalter_an("leinwand-klick-holt")
+    {
+        return;
+    }
+    let fenster = state.niri.window_under_cursor().map(|m| m.window.clone());
+    if let Some(win) = fenster {
+        if state.niri.layout.leinwand_fenster_zeigen(&win) {
+            // FIXME: granular.
+            state.niri.queue_redraw_all();
+        }
+    }
+}
+
+/// Rechtsklick auf den LEERRAUM öffnet das Desktop-Kontextmenü
+/// (matrix-kontext) — der Compositor liefert nur Ort und Anlass.
+/// Leisten-Flächen (Dock/Bar) zählen nicht als Leerraum (Fund 8.7.).
+pub fn rechtsklick_kontext(
+    state: &mut State,
+    button: Option<MouseButton>,
+    is_overview_open: bool,
+    mod_down: bool,
+) {
+    let pointer = state.niri.seat.get_pointer().unwrap();
+    if button != Some(MouseButton::Right)
+        || is_overview_open
+        || mod_down
+        || pointer.is_grabbed()
+        || !state.niri.config.borrow().gestures.leinwand_drag
+        || state.niri.window_under_cursor().is_some()
+    {
+        return;
+    }
+    let pos = pointer.current_location();
+    let auf_leiste = state.niri.output_under(pos).is_some_and(|(output, pos_in_out)| {
+        use smithay::wayland::shell::wlr_layer::Layer as WlrLayer;
+        let layers = smithay::desktop::layer_map_for_output(output);
+        [WlrLayer::Overlay, WlrLayer::Top, WlrLayer::Bottom]
+            .iter()
+            .any(|l| {
+                layers.layers_on(*l).any(|ls| {
+                    layers
+                        .layer_geometry(ls)
+                        .is_some_and(|g| g.to_f64().contains(pos_in_out))
+                })
+            })
+    });
+    if auf_leiste {
+        return;
+    }
+    crate::utils::spawning::spawn(
+        vec![
+            "sh".to_string(),
+            "-c".to_string(),
+            format!(
+                "PATH=$HOME/.local/bin:/usr/bin:$PATH exec matrix-kontext leinwand {} {}",
+                pos.x as i32, pos.y as i32
+            ),
+        ],
+        None,
+    );
+}
+
+/// MAUSRAD ODER TRACKPAD auf dem LEERRAUM blättert durch die Fenster —
+/// mit Klebe-Puffer (1 s ab letztem Tick, 24 px Standruhe). true =
+/// Ereignis gehört der Leinwand.
+pub fn rad_blaettern(
+    state: &mut State,
+    source: AxisSource,
+    vertical_amount_v120: Option<f64>,
+    vertical_px: f64,
+    is_overview_open: bool,
+    is_mru_open: bool,
+) -> bool {
+    if !(source == AxisSource::Wheel || source == AxisSource::Finger)
+        || is_overview_open
+        || is_mru_open
+        || !state.niri.config.borrow().gestures.leinwand_drag
+    {
+        return false;
+    }
+    let pointer = state.niri.seat.get_pointer().unwrap();
+    if pointer.is_grabbed() {
+        return false;
+    }
+    let mods = state.niri.seat.get_keyboard().unwrap().modifier_state();
+    if !modifiers_from_state(mods).is_empty() {
+        return false;
+    }
+    let location = pointer.current_location();
+    let under = state.niri.contents_under(location);
+    // Klebe-Puffer: Nach einem Blättern zentriert die Kamera — dabei
+    // kann ein Fenster unter die STEHENDE Maus rutschen. Solange der
+    // Zeiger (fast) am selben Ort steht und der letzte Blätter-Tick
+    // keine Sekunde her ist, gehört das Rad weiter der Leinwand;
+    // jeder Tick frischt die Frist auf. (Nutzer-Flow-Fund, 13.7.)
+    let klebt = state.niri.leinwand_blaettern_zuletzt.is_some_and(|(zeit, ort)| {
+        zeit.elapsed().as_millis() < 1000 && {
+            let d = location - ort;
+            d.x * d.x + d.y * d.y <= 24.0 * 24.0
+        }
+    });
+    if !(leerraum(&under) || klebt) {
+        return false;
+    }
+    let ticks = if source == AxisSource::Wheel {
+        let vertical = vertical_amount_v120.unwrap_or(0.);
+        state.niri.vertical_wheel_tracker.accumulate(vertical)
+    } else {
+        state.niri.leinwand_finger_roll += vertical_px;
+        let schritte = (state.niri.leinwand_finger_roll / 60.0).trunc() as i8;
+        if schritte != 0 {
+            state.niri.leinwand_finger_roll -= f64::from(schritte) * 60.0;
+        }
+        schritte
+    };
+    if ticks != 0 && crate::utils::matrix_schalter_an("leinwand-blaettern") {
+        let richtung = if ticks > 0 { 1 } else { -1 };
+        for _ in 0..ticks.abs() {
+            if let Some(id) = state.niri.layout.leinwand_blaettern(richtung) {
+                state.niri.layout.activate_window(&id);
+            }
+        }
+        // Der Fenster-Geist zeigt sich zum Blättern.
+        state.niri.fenster_geist.aktivieren();
+        // Klebe-Frist auffrischen: 1 s ab dem LETZTEN Tick.
+        state.niri.leinwand_blaettern_zuletzt =
+            Some((std::time::Instant::now(), location));
+        // FIXME: granular.
+        state.niri.queue_redraw_all();
+    }
+    true
+}
+
+/// EIN-FINGER-WISCH auf leerem Leinwandraum startet das Touch-Blättern —
+/// die App darunter sieht nie ein Down. true = Wisch übernommen.
+pub fn wisch_start(
+    state: &mut State,
+    slot: TouchSlot,
+    pos: Point<f64, Logical>,
+    under: &PointContents,
+    mods_leer: bool,
+) -> bool {
+    let Some(handle) = state.niri.seat.get_touch() else {
+        return false;
+    };
+    if !state.niri.config.borrow().gestures.leinwand_drag
+        || handle.is_grabbed()
+        || state.niri.leinwand_wisch.is_some()
+        || state.niri.screenshot_ui.is_open()
+        || state.niri.window_mru_ui.is_open()
+        || state.niri.layout.is_overview_open()
+        || !mods_leer
+        || !leerraum(under)
+    {
+        return false;
+    }
+    state.niri.leinwand_wisch = Some((slot, pos.y, 0.0));
+    true
+}
+
+/// Wisch-Ende: nichts an die App weiterreichen. true = verzehrt.
+pub fn wisch_ende(state: &mut State, slot: TouchSlot) -> bool {
+    if state.niri.leinwand_wisch.is_some_and(|(wslot, ..)| wslot == slot) {
+        state.niri.leinwand_wisch = None;
+        return true;
+    }
+    false
+}
+
+/// Laufender Wisch: alle 90 px ein Blätter-Schritt. Finger nach OBEN =
+/// vorwärts (Handy-Logik). true = Bewegung gehört der Leinwand.
+pub fn wisch_schritt(state: &mut State, slot: TouchSlot, pos: Point<f64, Logical>) -> bool {
+    let Some((wslot, letzte_y, sammler)) = state.niri.leinwand_wisch else {
+        return false;
+    };
+    if wslot != slot {
+        return false;
+    }
+    const SCHWELLE: f64 = 90.0;
+    let mut sammler = sammler + (pos.y - letzte_y);
+    let schritte = (sammler / SCHWELLE).trunc() as i32;
+    if schritte != 0 {
+        sammler -= f64::from(schritte) * SCHWELLE;
+        if crate::utils::matrix_schalter_an("leinwand-blaettern") {
+            let richtung = if schritte > 0 { -1 } else { 1 };
+            for _ in 0..schritte.unsigned_abs() {
+                if let Some(id) = state.niri.layout.leinwand_blaettern(richtung) {
+                    state.niri.layout.activate_window(&id);
+                }
+            }
+            state.niri.fenster_geist.aktivieren();
+            state.niri.queue_redraw_all();
+        }
+    }
+    state.niri.leinwand_wisch = Some((wslot, pos.y, sammler));
+    true
+}
