+//! Matrix Leinwand — das Modul-Zuhause der Fork-Identität (R46).
+//!
+//! Entkopplungs-Schritt 2 (Patch→Module): Alles, was die Leinwand dem
+//! Upstream hinzufügt, wohnt in eigenen Dateien — hier die Leerraum-
+//! Regel und der Fenster-Geist-Render-Hook; die Eingabe-Gesten liegen
+//! in input/leinwand.rs, die Kamera-Methoden in layout/
+//! floating_leinwand.rs. Upstream-Dateien behalten nur Einhak-Zeilen.
+
+use smithay::backend::renderer::element::Kind;
+use smithay::output::Output;
+use smithay::utils::{Logical, Point};
+
+use crate::niri::{Niri, PointContents};
+use crate::render_helpers::primary_gpu_texture::PrimaryGpuTextureRenderElement;
+use crate::render_helpers::renderer::NiriRenderer;
+use crate::render_helpers::texture::TextureRenderElement;
+
+/// Die Leerraum-Regel der Leinwand: kein Fenster, keine heiße Ecke,
+/// höchstens Background/Bottom-Layer unterm Zeiger — dort gehören
+/// Gesten der Leinwand, nicht den Apps.
+pub fn leerraum(under: &PointContents) -> bool {
+    under.window.is_none()
+        && !under.hot_corner
+        && under.layer.as_ref().map_or(true, |l| {
+            matches!(
+                l.layer(),
+                smithay::wayland::shell::wlr_layer::Layer::Background
+                    | smithay::wayland::shell::wlr_layer::Layer::Bottom
+            )
+        })
+}
+
+impl Niri {
+    /// Fenster-Geist der Leinwand: liegt die Maus auf dem Leerraum,
+    /// federt neben ihr die Icon-Wolke der offenen Apps ein. Liefert
+    /// das fertige Render-Element; None = nichts zu zeigen.
+    pub fn leinwand_geist_element<R: NiriRenderer>(
+        &self,
+        output: &Output,
+        renderer: &mut R,
+    ) -> Option<PrimaryGpuTextureRenderElement> {
+    // Matrix Leinwand: der Fenster-Geist — liegt die Maus auf dem
+    // Leerraum, federt neben ihr die Icon-Wolke der offenen Apps ein
+    // (räumlich wie auf der Leinwand; Sichtmitte = größeres Icon).
+        if !self.config.borrow().gestures.leinwand_drag {
+            return None;
+        }
+        let pointer = self.seat.get_pointer()?;
+        let ort = pointer.current_location();
+        let out_geo = self.global_space.output_geometry(output)?;
+        // Der Geist lebt nur auf dem Output unter dem Zeiger — nur
+        // dort darf auch das Sichtbarkeits-Ziel verstellt werden.
+        if !out_geo.to_f64().contains(ort) {
+            return None;
+        }
+
+        let mut fenster: Vec<(String, Point<f64, Logical>, bool)> = Vec::new();
+        let mut soll = self.pointer_visibility.is_visible()
+            && !self.layout.is_overview_open();
+        if soll {
+            let under = self.contents_under(ort);
+            soll = under.window.is_none()
+                && !under.hot_corner
+                && under.layer.as_ref().map_or(true, |l| {
+                    matches!(
+                        l.layer(),
+                        smithay::wayland::shell::wlr_layer::Layer::Background
+                            | smithay::wayland::shell::wlr_layer::Layer::Bottom
+                    )
+                });
+        }
+        if soll {
+            if let Some(mon) = self.layout.monitor_for_output(output) {
+                let info = mon.active_workspace_ref().leinwand_geist_info();
+                fenster = info
+                    .iter()
+                    .map(|(win, z, aktiv)| {
+                        let app_id = win
+                            .toplevel()
+                            .and_then(|t| {
+                                crate::utils::with_toplevel_role(t, |role| {
+                                    role.app_id.clone()
+                                })
+                            })
+                            .unwrap_or_default();
+                        (app_id, *z, *aktiv)
+                    })
+                    .collect();
+            }
+            soll = !fenster.is_empty();
+        }
+
+        // Geist-Modus (Nutzer 7.7.): standardmaessig nur nach dem
+        // Rad-Blaettern sichtbar — dann verweht er wieder.
+        let soll = self.fenster_geist.soll_zeigen(soll) && soll;
+        self.fenster_geist.setze_ziel(soll);
+        let alpha = self.fenster_geist.alpha();
+        if alpha <= 0.004 {
+            return None;
+        }
+
+        let scale = output.current_scale().fractional_scale();
+        let (buffer, position) = if soll {
+            let buffer = self.fenster_geist.render(renderer, scale, &fenster)?;
+            // Neben dem Zeiger, in den Schirm geklemmt (Scrollgeist-
+            // Grammatik: rechts, am Rand nach links flippend).
+            let groesse = buffer.logical_size();
+            let lokal = ort - out_geo.loc.to_f64();
+            let out_size = out_geo.size.to_f64();
+            let mut x = lokal.x + 26.0;
+            let mut y = lokal.y + 26.0;
+            if x + groesse.w > out_size.w - 8.0 {
+                x = lokal.x - groesse.w - 26.0;
+            }
+            if y + groesse.h > out_size.h - 8.0 {
+                y = (out_size.h - groesse.h - 8.0).max(8.0);
+            }
+            self.fenster_geist.merke_ort(x, y);
+            (buffer, (x, y))
+        } else {
+            // Ausblenden: die letzte Wolke verweht an Ort und Stelle.
+            let buffer = self.fenster_geist.letzte_textur()?;
+            (buffer, self.fenster_geist.letzter_ort())
+        };
+
+        let location = Point::from(position)
+            .to_physical_precise_round(scale)
+            .to_logical(scale);
+        let elem = TextureRenderElement::from_texture_buffer(
+            buffer,
+            location,
+            alpha as f32,
+            None,
+            None,
+            Kind::Unspecified,
+        );
+        Some(PrimaryGpuTextureRenderElement(elem))
+    }
+}
