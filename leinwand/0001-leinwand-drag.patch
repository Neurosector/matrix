diff --git a/src/ui/fenster_geist.rs b/src/ui/fenster_geist.rs
new file mode 100644
index 00000000..ae2c83a1
--- /dev/null
+++ b/src/ui/fenster_geist.rs
@@ -0,0 +1,599 @@
+//! Der Fenster-Geist (Matrix-Original, 7.7.2026).
+//!
+//! Auf der unendlichen Leinwand gibt es keinen Überblick über die offenen
+//! Fenster — der Fenster-Geist zeigt ihn: Liegt die Maus auf dem Leerraum,
+//! blendet neben ihr eine kleine Icon-Wolke aller offenen Apps ein,
+//! räumlich angeordnet wie die Fenster auf der Leinwand (eine
+//! Miniatur-Karte aus App-Icons). Das Fenster der Sichtmitte ist schlicht
+//! GRÖSSER als die anderen und trägt eine formgleiche Squircle-Kante.
+//! Verwandt mit dem Scrollgeist der MatrixKit-Apps: Orientierung
+//! erscheint bei der Maus, nicht am Rand — und federt ein und aus.
+//!
+//! GEISTKIT-REGEL: Die Geister gehören zu MatrixKit und halten dessen
+//! Gesetze ein — Farben kommen aus der lebenden DMS-Palette (hell wie
+//! dunkel), die Radien sind konzentrisch, die Schrift ist Inter, und
+//! „Bewegung reduzieren" (~/.config/matrix/bewegung) schaltet die
+//! Feder ab. Nichts ist hartkodiert, was das System lebendig macht.
+
+use std::cell::{Cell, RefCell};
+use std::collections::HashMap;
+use std::hash::{Hash, Hasher};
+use std::path::PathBuf;
+use std::rc::Rc;
+
+use niri_config::Config;
+use pangocairo::cairo::{self, Format, ImageSurface};
+use pangocairo::pango::{self, FontDescription};
+use smithay::backend::renderer::gles::{GlesRenderer, GlesTexture};
+use smithay::utils::{Logical, Point, Transform};
+
+use crate::animation::{Animation, Clock};
+use crate::render_helpers::renderer::NiriRenderer;
+use crate::render_helpers::texture::TextureBuffer;
+
+/// Logische Größe eines Icons in der Wolke.
+const ICON: f64 = 24.0;
+/// Das Fenster der Sichtmitte: einfach größer statt beringt.
+const AKTIV: f64 = 34.0;
+/// Maximale Ausdehnung des Zentren-Clusters (ohne Polster).
+/// Fenster-Geist 3.0 (Nutzer-Entwurf): keine Karten-Projektion mehr —
+/// eine ruhige LISTE, höchstens drei Icons untereinander, das aktive in
+/// der Mitte. Beim Blättern rückt die Reihe mit Umlauf durch.
+const LISTE_MAX: usize = 3;
+const LISTE_TAKT: f64 = AKTIV + 10.0;
+const POLSTER: f64 = 12.0;
+/// Mindestabstand zweier Icon-Zentren (Entzerrung naher Fenster).
+
+/// Squircle-Radius der Icon-Kacheln — dieselbe Kurve wie die
+/// MatrixKit-App-Icons (~28 % der Kantenlänge).
+fn ecke(gr: f64) -> f64 {
+    gr * 0.28
+}
+
+/// Die lebende MatrixKit-Palette, soweit der Geist sie braucht
+/// (GeistKit-Regel: keine hartkodierten Farben).
+struct GeistPalette {
+    panel: (f64, f64, f64),
+    kante: (f64, f64, f64),
+    aktiv: (f64, f64, f64),
+    kachel: (f64, f64, f64),
+    kachel_text: (f64, f64, f64),
+}
+
+impl Default for GeistPalette {
+    /// Fallback = die Matrix-Standardwerte (dunkel) — nur wenn die
+    /// DMS-Palette (noch) nicht existiert.
+    fn default() -> Self {
+        Self {
+            panel: hex_rgb("#2b2b22").unwrap(),
+            kante: hex_rgb("#e4e3d7").unwrap(),
+            aktiv: hex_rgb("#bece7f").unwrap(),
+            kachel: hex_rgb("#3f4c0a").unwrap(),
+            kachel_text: hex_rgb("#daeb99").unwrap(),
+        }
+    }
+}
+
+fn hex_rgb(hex: &str) -> Option<(f64, f64, f64)> {
+    let h = hex.trim().trim_start_matches('#');
+    if h.len() < 6 {
+        return None;
+    }
+    let teil = |a: usize| u8::from_str_radix(&h[a..a + 2], 16).ok();
+    Some((
+        f64::from(teil(0)?) / 255.0,
+        f64::from(teil(2)?) / 255.0,
+        f64::from(teil(4)?) / 255.0,
+    ))
+}
+
+fn dms_colors_pfad() -> Option<PathBuf> {
+    let home = std::env::var("HOME").ok()?;
+    Some(PathBuf::from(home).join(".cache/DankMaterialShell/dms-colors.json"))
+}
+
+/// Palette aus der DMS-Farbdatei lesen — Rollen wie mk::Palette::load()
+/// im matrixkit-theme, Hell-/Dunkel-Wahl aus der DMS-Session.
+fn palette_laden() -> GeistPalette {
+    let d = GeistPalette::default();
+    let Some(pfad) = dms_colors_pfad() else { return d };
+    let Ok(raw) = std::fs::read_to_string(pfad) else { return d };
+    let Ok(json) = serde_json::from_str::<serde_json::Value>(&raw) else { return d };
+    let hell = std::env::var("HOME")
+        .ok()
+        .and_then(|h| {
+            std::fs::read_to_string(format!("{h}/.local/state/DankMaterialShell/session.json"))
+                .ok()
+        })
+        .and_then(|s| serde_json::from_str::<serde_json::Value>(&s).ok())
+        .and_then(|v| v.get("isLightMode").and_then(|b| b.as_bool()))
+        .unwrap_or(false);
+    let modus = &json["colors"][if hell { "light" } else { "dark" }];
+    let rolle = |name: &str, fallback: (f64, f64, f64)| {
+        modus
+            .get(name)
+            .and_then(|v| v.as_str())
+            .and_then(hex_rgb)
+            .unwrap_or(fallback)
+    };
+    GeistPalette {
+        panel: rolle("surface_container_high", d.panel),
+        kante: rolle("on_surface", d.kante),
+        aktiv: rolle("primary", d.aktiv),
+        kachel: rolle("primary_container", d.kachel),
+        kachel_text: rolle("on_primary_container", d.kachel_text),
+    }
+}
+
+/// MatrixKit-Barrierefreiheit: Bewegung reduzieren gilt auch für Geister.
+fn bewegung_reduziert() -> bool {
+    std::env::var("HOME")
+        .ok()
+        .and_then(|h| std::fs::read_to_string(format!("{h}/.config/matrix/bewegung")).ok())
+        .map(|s| s.trim() == "reduziert")
+        .unwrap_or(false)
+}
+
+/// Änderungsstempel der Farbdatei — wandert in den Textur-Hash, damit
+/// ein Wallpaper-/Moduswechsel die Wolke sofort neu einfärbt.
+fn palette_stempel() -> u64 {
+    dms_colors_pfad()
+        .and_then(|p| std::fs::metadata(p).ok())
+        .and_then(|m| m.modified().ok())
+        .and_then(|t| t.duration_since(std::time::UNIX_EPOCH).ok())
+        .map(|d| d.as_secs())
+        .unwrap_or(0)
+}
+
+/// Ein- und Ausblenden wie der Scrollgeist: weiche Feder, kein Springen.
+enum Lage {
+    Versteckt,
+    Erscheint(Animation),
+    Da,
+    Verschwindet(Animation),
+}
+
+/// Wann zeigt sich der Geist? (~/.config/matrix/leinwand-geist)
+#[derive(Clone, Copy, PartialEq, Eq)]
+pub enum GeistModus {
+    /// Nur nach dem Rad-Blättern — erscheint, hilft, verweht (Default).
+    Scrollen,
+    /// Immer, solange die Maus auf dem Leerraum liegt.
+    Immer,
+    Aus,
+}
+
+pub struct FensterGeist {
+    clock: Clock,
+    config: Rc<RefCell<Config>>,
+    lage: RefCell<Lage>,
+    /// app_id → dekodiertes Icon (None = Fallback-Kachel merken).
+    icons: RefCell<HashMap<String, Option<ImageSurface>>>,
+    /// Zuletzt gerenderte Wolke: (Layout-Hash, Textur).
+    buffer: RefCell<Option<(u64, TextureBuffer<GlesTexture>)>>,
+    /// Letzter Anzeigeort (Ausblenden geschieht an Ort und Stelle).
+    letzter_ort: Cell<(f64, f64)>,
+    /// Letztes Rad-Blättern — im Scrollen-Modus lebt der Geist 1,6 s.
+    zuletzt_aktiv: Cell<Option<std::time::Instant>>,
+    /// Modus-Cache (Datei alle 2 s frisch gelesen).
+    modus_cache: Cell<Option<(std::time::Instant, GeistModus)>>,
+}
+
+impl FensterGeist {
+    pub fn new(clock: Clock, config: Rc<RefCell<Config>>) -> Self {
+        Self {
+            clock,
+            config,
+            lage: RefCell::new(Lage::Versteckt),
+            icons: RefCell::new(HashMap::new()),
+            buffer: RefCell::new(None),
+            letzter_ort: Cell::new((0.0, 0.0)),
+            zuletzt_aktiv: Cell::new(None),
+            modus_cache: Cell::new(None),
+        }
+    }
+
+    /// Rad-Blättern meldet sich — der Geist zeigt sich (Scrollen-Modus).
+    pub fn aktivieren(&self) {
+        self.zuletzt_aktiv.set(Some(std::time::Instant::now()));
+    }
+
+    fn modus(&self) -> GeistModus {
+        if let Some((wann, m)) = self.modus_cache.get() {
+            if wann.elapsed().as_secs() < 2 {
+                return m;
+            }
+        }
+        let m = match crate::utils::matrix_einstellung("leinwand-geist").as_deref() {
+            Some("immer") => GeistModus::Immer,
+            Some("aus") => GeistModus::Aus,
+            _ => GeistModus::Scrollen,
+        };
+        self.modus_cache.set(Some((std::time::Instant::now(), m)));
+        m
+    }
+
+    /// Soll der Geist sichtbar sein? (leerraum = Maus auf freier Leinwand)
+    pub fn soll_zeigen(&self, leerraum: bool) -> bool {
+        match self.modus() {
+            GeistModus::Aus => false,
+            GeistModus::Immer => leerraum,
+            GeistModus::Scrollen => {
+                leerraum
+                    && self
+                        .zuletzt_aktiv
+                        .get()
+                        .is_some_and(|t| t.elapsed().as_millis() < 1600)
+            }
+        }
+    }
+
+    fn animation(&self, from: f64, to: f64) -> Animation {
+        let c = self.config.borrow();
+        Animation::new(
+            self.clock.clone(),
+            from,
+            to,
+            0.,
+            c.animations.config_notification_open_close.0,
+        )
+    }
+
+    /// Soll-Sichtbarkeit setzen — startet bei Wechsel die Feder.
+    /// (RefCell, weil der Entscheid im Render-Pfad fällt.)
+    pub fn setze_ziel(&self, sichtbar: bool) {
+        let mut lage = self.lage.borrow_mut();
+        // MatrixKit-Regel: reduzierte Bewegung = sofort, keine Feder.
+        if bewegung_reduziert() {
+            *lage = if sichtbar { Lage::Da } else { Lage::Versteckt };
+            return;
+        }
+        match (&*lage, sichtbar) {
+            (Lage::Versteckt | Lage::Verschwindet(_), true) => {
+                let von = match &*lage {
+                    Lage::Verschwindet(anim) => anim.value().clamp(0.0, 1.0),
+                    _ => 0.0,
+                };
+                *lage = Lage::Erscheint(self.animation(von, 1.0));
+            }
+            (Lage::Da | Lage::Erscheint(_), false) => {
+                let von = match &*lage {
+                    Lage::Erscheint(anim) => anim.value().clamp(0.0, 1.0),
+                    _ => 1.0,
+                };
+                *lage = Lage::Verschwindet(self.animation(von, 0.0));
+            }
+            _ => (),
+        }
+    }
+
+    /// Fertige Übergänge auflösen (aus Niri::advance_animations).
+    pub fn advance_animations(&self) {
+        let mut lage = self.lage.borrow_mut();
+        match &*lage {
+            Lage::Erscheint(anim) if anim.is_done() => *lage = Lage::Da,
+            Lage::Verschwindet(anim) if anim.is_clamped_done() => *lage = Lage::Versteckt,
+            _ => (),
+        }
+    }
+
+    pub fn are_animations_ongoing(&self) -> bool {
+        matches!(
+            &*self.lage.borrow(),
+            Lage::Erscheint(_) | Lage::Verschwindet(_)
+        )
+    }
+
+    /// Aktuelle Deckkraft der Feder.
+    pub fn alpha(&self) -> f64 {
+        match &*self.lage.borrow() {
+            Lage::Versteckt => 0.0,
+            Lage::Da => 1.0,
+            Lage::Erscheint(anim) | Lage::Verschwindet(anim) => anim.value().clamp(0.0, 1.0),
+        }
+    }
+
+    pub fn merke_ort(&self, x: f64, y: f64) {
+        self.letzter_ort.set((x, y));
+    }
+
+    pub fn letzter_ort(&self) -> (f64, f64) {
+        self.letzter_ort.get()
+    }
+
+    /// Die zuletzt gezeichnete Wolke (fürs Ausblenden an Ort und Stelle).
+    pub fn letzte_textur(&self) -> Option<TextureBuffer<GlesTexture>> {
+        self.buffer.borrow().as_ref().map(|(_, b)| b.clone())
+    }
+
+    /// Die Icon-Wolke als Textur — gecacht, solange sich Fensterbestand,
+    /// Anordnung und Sichtmitte nicht ändern.
+    pub fn render<R: NiriRenderer>(
+        &self,
+        renderer: &mut R,
+        scale: f64,
+        fenster: &[(String, Point<f64, Logical>, bool)],
+    ) -> Option<TextureBuffer<GlesTexture>> {
+        if fenster.is_empty() {
+            return None;
+        }
+
+        // 1) Blätter-Reihenfolge: wie das Mausrad — von links nach rechts.
+        let mut reihe: Vec<usize> = (0..fenster.len()).collect();
+        reihe.sort_by(|&a, &b| {
+            fenster[a]
+                .1
+                .x
+                .partial_cmp(&fenster[b].1.x)
+                .unwrap_or(std::cmp::Ordering::Equal)
+                .then(
+                    fenster[a]
+                        .1
+                        .y
+                        .partial_cmp(&fenster[b].1.y)
+                        .unwrap_or(std::cmp::Ordering::Equal),
+                )
+        });
+
+        // 2) Der Ausschnitt: höchstens DREI untereinander — das aktive in
+        //    der Mitte, der Vorgänger darüber, der Nachfolger darunter
+        //    (mit Umlauf, wie das Blättern selbst).
+        let aktiv_pos = reihe.iter().position(|&i| fenster[i].2).unwrap_or(0);
+        let n = reihe.len();
+        let auswahl: Vec<usize> = if n <= LISTE_MAX {
+            reihe
+        } else {
+            vec![
+                reihe[(aktiv_pos + n - 1) % n],
+                reihe[aktiv_pos],
+                reihe[(aktiv_pos + 1) % n],
+            ]
+        };
+        let liste: Vec<(String, Point<f64, Logical>, bool)> =
+            auswahl.iter().map(|&i| fenster[i].clone()).collect();
+
+        // 3) Spalten-Plätze: Zentren im festen Takt, eine Spalte.
+        let rand = POLSTER + AKTIV / 2.0;
+        let breite = 2.0 * rand;
+        let hoehe = (liste.len().saturating_sub(1)) as f64 * LISTE_TAKT + 2.0 * rand;
+        let plaetze: Vec<(f64, f64, bool)> = liste
+            .iter()
+            .enumerate()
+            .map(|(k, (_, _, aktiv))| (rand, rand + k as f64 * LISTE_TAKT, *aktiv))
+            .collect();
+
+        // Cache-Schlüssel: Apps + gerasterte Plätze + Sichtmitte + Scale.
+        let mut h = std::collections::hash_map::DefaultHasher::new();
+        for ((app, _, _), (x, y, aktiv)) in liste.iter().zip(&plaetze) {
+            app.hash(&mut h);
+            (((*x / 3.0) as i64), ((*y / 3.0) as i64), *aktiv).hash(&mut h);
+        }
+        scale.to_bits().hash(&mut h);
+        palette_stempel().hash(&mut h);
+        let schluessel = h.finish();
+
+        if let Some((k, buf)) = &*self.buffer.borrow() {
+            if *k == schluessel {
+                return Some(buf.clone());
+            }
+        }
+
+        let buf = self
+            .zeichnen(
+                renderer.as_gles_renderer(),
+                scale,
+                breite,
+                hoehe,
+                &liste,
+                &plaetze,
+            )
+            .ok()?;
+        *self.buffer.borrow_mut() = Some((schluessel, buf.clone()));
+        Some(buf)
+    }
+
+    fn zeichnen(
+        &self,
+        renderer: &mut GlesRenderer,
+        scale: f64,
+        breite: f64,
+        hoehe: f64,
+        fenster: &[(String, Point<f64, Logical>, bool)],
+        plaetze: &[(f64, f64, bool)],
+    ) -> anyhow::Result<TextureBuffer<GlesTexture>> {
+        let b_phys = (breite * scale).round() as i32;
+        let h_phys = (hoehe * scale).round() as i32;
+        let surface = ImageSurface::create(Format::ARgb32, b_phys, h_phys)?;
+        let cr = cairo::Context::new(&surface)?;
+        cr.scale(scale, scale);
+
+        // GeistKit: die lebende Palette — folgt Wallpaper und Hell/Dunkel.
+        let p = palette_laden();
+
+        // Panel: leicht durchscheinende Fläche mit feiner Kante.
+        // Radius KONZENTRISCH zu den Icon-Squircles (mk::radius-Regel:
+        // außen = innen + Abstand).
+        let panel_radius = ecke(ICON) + POLSTER;
+        rounded_rect(&cr, 0.5, 0.5, breite - 1.0, hoehe - 1.0, panel_radius);
+        cr.set_source_rgba(p.panel.0, p.panel.1, p.panel.2, 0.92);
+        cr.fill_preserve()?;
+        cr.set_source_rgba(p.kante.0, p.kante.1, p.kante.2, 0.12);
+        cr.set_line_width(1.0);
+        cr.stroke()?;
+
+        let mut icons = self.icons.borrow_mut();
+        // Das aktive Icon zuletzt zeichnen — es liegt sichtbar obenauf.
+        let mut reihenfolge: Vec<usize> = (0..plaetze.len()).collect();
+        reihenfolge.sort_by_key(|&i| plaetze[i].2);
+        for i in reihenfolge {
+            let (app_id, _, _) = &fenster[i];
+            let (x, y, aktiv) = plaetze[i];
+            let icon = icons
+                .entry(app_id.clone())
+                .or_insert_with(|| icon_laden(app_id));
+
+            let gr = if aktiv { AKTIV } else { ICON };
+            let ox = x - gr / 2.0;
+            let oy = y - gr / 2.0;
+            // Endlos-Rad-Gefühl (Nutzer-Entwurf): oben und unten faden
+            // die Nachbarn aus, nur die Sichtmitte steht voll da.
+            let fade = if aktiv { 1.0 } else { 0.45 };
+
+            // Einheitliche Squircle-Form für ALLE Icons (Konsistenz —
+            // auch Fremd-Icons bekommen die MatrixKit-Kurve).
+            cr.save()?;
+            cr.push_group();
+            rounded_rect(&cr, ox, oy, gr, gr, ecke(gr));
+            cr.clip();
+            match icon {
+                Some(img) => {
+                    let iw = img.width() as f64;
+                    let ih = img.height() as f64;
+                    cr.translate(ox, oy);
+                    cr.scale(gr / iw, gr / ih);
+                    cr.set_source_surface(img, 0.0, 0.0)?;
+                    cr.paint()?;
+                }
+                None => {
+                    // Fallback: getönte Kachel mit Anfangsbuchstaben
+                    // (primary_container / on_primary_container).
+                    cr.set_source_rgba(p.kachel.0, p.kachel.1, p.kachel.2, 1.0);
+                    cr.paint()?;
+                    let buchstabe = app_id
+                        .rsplit(['.', '-'])
+                        .next()
+                        .and_then(|t| t.chars().next())
+                        .unwrap_or('?')
+                        .to_uppercase()
+                        .to_string();
+                    let layout = pangocairo::functions::create_layout(&cr);
+                    let mut font = FontDescription::from_string("Inter Variable Bold 12");
+                    font.set_absolute_size(gr * 0.55 * f64::from(pango::SCALE));
+                    layout.set_font_description(Some(&font));
+                    layout.set_text(&buchstabe);
+                    let (tw, th) = layout.pixel_size();
+                    cr.move_to(
+                        ox + (gr - f64::from(tw)) / 2.0,
+                        oy + (gr - f64::from(th)) / 2.0,
+                    );
+                    cr.set_source_rgba(p.kachel_text.0, p.kachel_text.1, p.kachel_text.2, 1.0);
+                    pangocairo::functions::show_layout(&cr, &layout);
+                }
+            }
+            cr.pop_group_to_source()?;
+            cr.paint_with_alpha(fade)?;
+            cr.restore()?;
+
+            // Sichtmitte: größeres Icon + formgleiche Squircle-Kante
+            // (KEIN Kreis — die Kante folgt der Icon-Form, konzentrisch).
+            if aktiv {
+                let luft = 2.5;
+                rounded_rect(
+                    &cr,
+                    ox - luft,
+                    oy - luft,
+                    gr + 2.0 * luft,
+                    gr + 2.0 * luft,
+                    ecke(gr) + luft,
+                );
+                cr.set_source_rgba(p.aktiv.0, p.aktiv.1, p.aktiv.2, 0.95);
+                cr.set_line_width(2.0);
+                cr.stroke()?;
+            }
+        }
+        drop(cr);
+
+        let data = surface.take_data().unwrap();
+        let buffer = TextureBuffer::from_memory(
+            renderer,
+            &data,
+            smithay::backend::allocator::Fourcc::Argb8888,
+            (b_phys, h_phys),
+            false,
+            scale,
+            Transform::Normal,
+            Vec::new(),
+        )?;
+        Ok(buffer)
+    }
+}
+
+fn rounded_rect(cr: &cairo::Context, x: f64, y: f64, b: f64, h: f64, r: f64) {
+    let r = r.min(b / 2.0).min(h / 2.0);
+    cr.new_path();
+    cr.arc(x + b - r, y + r, r, -std::f64::consts::FRAC_PI_2, 0.0);
+    cr.arc(x + b - r, y + h - r, r, 0.0, std::f64::consts::FRAC_PI_2);
+    cr.arc(
+        x + r,
+        y + h - r,
+        r,
+        std::f64::consts::FRAC_PI_2,
+        std::f64::consts::PI,
+    );
+    cr.arc(
+        x + r,
+        y + r,
+        r,
+        std::f64::consts::PI,
+        1.5 * std::f64::consts::PI,
+    );
+    cr.close_path();
+}
+
+/// App-Icon als cairo-Surface: PNG aus den hicolor-Themes, in
+/// premultipliziertes ARgb32 gewandelt. None = kein Icon gefunden.
+fn icon_laden(app_id: &str) -> Option<ImageSurface> {
+    if app_id.is_empty() {
+        return None;
+    }
+    let pfad = icon_pfad(app_id)?;
+    let file = std::io::BufReader::new(std::fs::File::open(pfad).ok()?);
+    let mut reader = png::Decoder::new(file).read_info().ok()?;
+    let mut buf = vec![0u8; reader.output_buffer_size()?];
+    let info = reader.next_frame(&mut buf).ok()?;
+    if info.bit_depth != png::BitDepth::Eight {
+        return None;
+    }
+    let (w, h) = (info.width as usize, info.height as usize);
+    let stride = Format::ARgb32.stride_for_width(w as u32).ok()? as usize;
+    let mut daten = vec![0u8; stride * h];
+    let kanaele = match info.color_type {
+        png::ColorType::Rgba => 4,
+        png::ColorType::Rgb => 3,
+        _ => return None,
+    };
+    for zeile in 0..h {
+        for spalte in 0..w {
+            let q = (zeile * w + spalte) * kanaele;
+            let (r, g, b, a) = if kanaele == 4 {
+                (buf[q], buf[q + 1], buf[q + 2], buf[q + 3])
+            } else {
+                (buf[q], buf[q + 1], buf[q + 2], 255)
+            };
+            // Premultiply (cairo ARgb32) + native-endian Pixelwort.
+            let m = |k: u8| ((k as u32 * a as u32) / 255) as u32;
+            let px: u32 = ((a as u32) << 24) | (m(r) << 16) | (m(g) << 8) | m(b);
+            let z = zeile * stride + spalte * 4;
+            daten[z..z + 4].copy_from_slice(&px.to_ne_bytes());
+        }
+    }
+    ImageSurface::create_for_data(daten, Format::ARgb32, w as i32, h as i32, stride as i32).ok()
+}
+
+fn icon_pfad(app_id: &str) -> Option<PathBuf> {
+    let mut wurzeln: Vec<String> = Vec::new();
+    if let Ok(h) = std::env::var("HOME") {
+        wurzeln.push(format!("{h}/.local/share/icons"));
+    }
+    wurzeln.push("/usr/share/icons".to_string());
+    wurzeln.push("/var/lib/flatpak/exports/share/icons".to_string());
+    for wurzel in &wurzeln {
+        for groesse in ["128x128", "64x64", "256x256", "48x48", "512x512"] {
+            let p = PathBuf::from(format!("{wurzel}/hicolor/{groesse}/apps/{app_id}.png"));
+            if p.exists() {
+                return Some(p);
+            }
+        }
+    }
+    None
+}
