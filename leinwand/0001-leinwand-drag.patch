+/// Matrix-Einstellungs-Kultur (~/.config/matrix/<name>): kleine, lesbare
+/// Dateien — die Leinwand liest sie LIVE, Änderungen wirken sofort.
+pub fn matrix_einstellung(name: &str) -> Option<String> {
+    let home = std::env::var("HOME").ok()?;
+    std::fs::read_to_string(format!("{home}/.config/matrix/{name}"))
+        .ok()
+        .map(|s| s.trim().to_string())
+}
+
+/// Schalter-Konvention: fehlende Datei = AN; nur "aus" schaltet ab.
+pub fn matrix_schalter_an(name: &str) -> bool {
+    matrix_einstellung(name).as_deref() != Some("aus")
+}
